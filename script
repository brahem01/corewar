#!/bin/bash
# compare.sh

REF="playground/players_src/pierino.cor"
YOURS="players/bin/pierino.cor"

echo "=== File sizes ==="
ls -l $REF $YOURS

echo -e "\n=== Byte-by-byte comparison ==="
cmp $REF $YOURS && echo "✓ Files are identical!" || echo "✗ Files differ"

echo -e "\n=== Hex diff (first 20 differences) ==="
diff -u <(xxd $REF) <(xxd $YOURS) | head -40
